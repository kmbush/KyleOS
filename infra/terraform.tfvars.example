# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored (ADR-006).
# Only these four values are account-specific; everything else has a sane default
# in variables.tf. Placeholders only here — no real account values are committed.

region = "us-west-2"

# Optional. Leave "" to deploy CloudFront-URL-only (no ACM cert, no DNS) — the right
# choice if you have no domain, or while an old site still serves the domain. Set it
# to your apex (which must already be a Route 53 hosted zone) to attach the domain.
domain_name = ""

contact_sender_email    = "<you@example.com>"
contact_recipient_email = "<you@example.com>"

# GitHub Actions OIDC deploy role (Phase 5).
github_repo     = "<owner>/<repo>"
tf_state_bucket = "<your-terraform-state-bucket>"

# The GitHub OIDC provider usually already exists in the account, so this defaults to
# false (the role references it). Set true only in a fresh account that has none yet.
# create_github_oidc_provider = false
